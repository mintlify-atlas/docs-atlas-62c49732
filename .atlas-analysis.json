  "keyFeatures": [
    "Generate Markdown folder structure with one click",
    "20+ customizable drawing styles including emoji and ASCII options",
    "Flexible exclusion patterns using glob syntax",
    "Optional .gitignore integration",
    "Automatic clipboard integration",
    "Configurable recursion depth"
  ],
  "publicApiSurface": [
    "extension.generateMarkdownStructure - Main command to generate structure",
    "draw.folder.structure.exclude - Configuration for exclusion patterns",
    "draw.folder.structure.style - Configuration for drawing style",
    "draw.folder.structure.allowRecursion - Configuration for recursive exploration",
    "draw.folder.structure.respectGitignore - Configuration for .gitignore support",
    "Style enum - All available drawing styles (ClassicDashes, EmojiDashes, MinimalistDots, etc.)",
    "generateStructure() - Core function to generate folder structure",
    "getPrefix() - Function to get style-specific prefix for each item",
    "findFiles() - Function to discover files with exclusion support"
